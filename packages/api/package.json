{
  "name": "@rhizomatic/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@rhizomatic/common": "workspace:*",
    "@rhizomatic/graph": "workspace:*",
    "@rhizomatic/search": "workspace:*",
    "@rhizomatic/ingestion": "workspace:*",
    "effect": "^3.12.0",
    "fastify": "^5.1.0",
    "mercurius": "^15.0.0"
  },
  "devDependencies": { "typescript": "^5.6.0", "tsx": "^4.19.0", "vitest": "^2.1.0" }
}
