{
  "name": "@rhizomatic/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": { "rhizomatic": "./dist/cli.js" },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/cli.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@rhizomatic/common": "workspace:*",
    "@rhizomatic/graph": "workspace:*",
    "@rhizomatic/search": "workspace:*",
    "@rhizomatic/ingestion": "workspace:*",
    "effect": "^3.12.0",
    "commander": "^12.1.0"
  },
  "devDependencies": { "typescript": "^5.6.0", "tsx": "^4.19.0", "vitest": "^2.1.0" }
}
