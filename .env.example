# ============================================================================
# Rhizomatic — Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env
#
# These variables are used by both Docker Compose and the application.
# ============================================================================

# --------------------------------------------------------------------------
# Neo4j
# --------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=rhizomatic-dev

# --------------------------------------------------------------------------
# Elasticsearch
# --------------------------------------------------------------------------
ELASTICSEARCH_URL=http://localhost:9200

# --------------------------------------------------------------------------
# Redis
# --------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --------------------------------------------------------------------------
# File Storage
# --------------------------------------------------------------------------
# Local filesystem path for storing uploaded documents.
# Relative to the project root.
FILE_STORAGE_PATH=./data/files

# --------------------------------------------------------------------------
# Processing Pipeline
# --------------------------------------------------------------------------
# Number of concurrent Python workers for processing jobs.
PROCESSOR_CONCURRENCY=2

# Embedding model name (from sentence-transformers).
# all-MiniLM-L6-v2: fast, 384 dimensions, good baseline.
# all-mpnet-base-v2: slower, 768 dimensions, higher quality.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --------------------------------------------------------------------------
# Application
# --------------------------------------------------------------------------
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
LOG_LEVEL=debug
